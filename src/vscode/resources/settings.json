{
  "chat.editor.fontFamily": "",
  "diffEditor.wordWrap": "on",
  "diffEditor.codeLens": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "editor.unicodeHighlight.nonBasicASCII": false,
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.fontLigatures": true,
  "editor.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.fontSize": 14,
  "editor.fontWeight": "350",
  "editor.largeFileOptimizations": false,
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "smooth",
  "editor.smoothScrolling": true,
  "editor.inlineSuggest.fontFamily": "JetBrainsMono Nerd Font Mono",
  "editor.overtypeOnPaste": false,
  "editor.stickyScroll.scrollWithEditor": false,
  "editor.maxTokenizationLineLength": 50000,
  "editor.stickyScroll.enabled": false,
  "editor.accessibilitySupport": "off",
  "extensions.ignoreRecommendations": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.insertFinalNewline": true,
  "files.associations": {
    "*.base": "json"
  },
  "files.readonlyInclude": {
    ".+\\(Pull Request\\)+": true
  },
  "files.autoSave": "afterDelay",
  "security.workspace.trust.untrustedFiles": "newWindow",
  "search.exclude": {
    ".lsp/.cache": true
  },
  "workbench.panel.defaultLocation": "right",
  "workbench.editor.showTabs": "single",
  "workbench.editor.closeOnFileDelete": true,
  "workbench.tree.enableStickyScroll": false,
  "workbench.list.smoothScrolling": true,
  "workbench.editor.navigationScope": "editorGroup",
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.editor.splitOnDragAndDrop": false,
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.limit.value": 1,
  "workbench.startupEditor": "none",
  "window.nativeTabs": true,
  "window.newWindowDimensions": "maximized",
  "window.zoomLevel": 0.9,
  // Terminal
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font Mono",
  "terminal.integrated.scrollback": 12000,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.stickyScroll.enabled": true,
  "terminal.integrated.smoothScrolling": true,
  // Workaround to fix wrong terminal pathing 
  // https://github.com/Microsoft/vscode-python/issues/4434
  "terminal.integrated.env.osx": {
    "PATH": ""
  },
  // Shell
  "[shellscript]": {
    "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
  },
  // Git
  "githubPullRequests.fileListLayout": "tree",
  "git.autofetch": true,
  "gitblame.inlineMessageEnabled": true,
  "gitblame.inlineMessageFormat": "${author.name} (${time.ago})",
  "gitblame.statusBarMessageClickAction": "Open tool URL",
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "githubPullRequests.focusedMode": "overview",
  "githubPullRequests.pullBranch": "never",
  // Copilot
  "github.copilot.chat.edits.temporalContext.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "clojure": false
  },
  // Error Lens
  "errorLens.messageEnabled": true,
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning",
    "info",
    "hint"
  ],
  // Codesnap
  "codesnap.transparentBackground": true,
  "codesnap.shutterAction": "copy",
  "codesnap.target": "window",
  "codesnap.showWindowControls": false,
  // Markdown
  "[markdown]": {
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    },
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "calva.fmt.configPath": "CLOJURE-LSP",
  "calva.paredit.defaultKeyMap": "original",
  "calva.prettyPrintingOptions": {
    "printEngine": "puget",
    "enabled": true,
    "width": 120,
    "maxLength": 50
  },
  "calva.definitionProviderPriority": [
    "lsp",
    "repl"
  ],
  "calva.legacyPrintBareReplWindowOutput": false,
  "calva.outputDestinations": {
    "evalResults": "terminal",
    "evalOutput": "terminal",
    "otherOutput": "terminal"
  },
  "calva.fmt.newIndentEngine": true,
  "calva.showCalvaSaysOnStart": false,
  "calva.autoOpenJackInTerminal": false,
  "calva.autoOpenREPLWindow": false,
  "calva.useLegacyReplWindowPath": false,
  "calva.autoOpenInspector": false,
  "calva.redirectServerOutputToRepl": false,
  "calva.autoEvaluateCode": {
    "onConnect": {
      "clj": "(when-let [requires (resolve 'clojure.main/repl-requires)] (clojure.core/apply clojure.core/require @requires))(require '[clojure.tools.namespace.repl] '[clojure.tools.namespace.find] '[clojure.java.io])",
      "cljs": "(try (require '[cljs.repl :refer [apropos dir doc find-doc print-doc pst source]]) (catch :default e (js/console.warn \"Failed to require cljs.repl utilities:\" (.-message e))))"
    },
    "onFileLoaded": {
      "clj": null,
      "cljs": null
    }
  },
  // Theming
  "workbench.colorTheme": "Catppuccin Frappé",
  "editor.tokenColorCustomizations": {
    "[Catppuccin Frappé]": {
      "textMateRules": [
        {
          "scope": "keyword.control",
          "settings": {
            "foreground": "#EA999C"
          }
        },
        {
          "scope": [
            "entity.name.namespace.clojure",
            "storage",
            "entity.name.type"
          ],
          "settings": {
            "foreground": "#96eade"
          }
        },
        {
          "scope": [
            "entity.name.function",
            "meta.require",
            "support.function.any-method",
            "variable.function"
          ],
          "settings": {
            "foreground": "#e9d1d1",
            "fontStyle": ""
          }
        },
        {
          "scope": "source.clojure,variable.other.readwrite,meta.object-literal.key,support.variable.property,support.variable.object.process,support.variable.object.node",
          "settings": {
            "foreground": "#e2dfe4"
          }
        },
        {
          "scope": "entity.name.type",
          "settings": {
            "foreground": "#95e6cb"
          }
        },
        {
          "scope": "string",
          "settings": {
            "foreground": "#b6ecc6f3"
          }
        },
      ]
    },
    "[Afterglow Remastered]": {
      "textMateRules": [
        {
          "scope": "keyword.control",
          "settings": {
            "foreground": "#e695e3"
          }
        },
        {
          "scope": "entity.name.namespace.clojure",
          "settings": {
            "foreground": "#0bfcd8"
          }
        },
        {
          "scope": [
            "entity.name.function",
            "meta.require",
            "support.function.any-method",
            "variable.function"
          ],
          "settings": {
            "foreground": "#6dcbfa",
            "fontStyle": ""
          }
        },
        {
          "scope": "source.clojure,variable.other.readwrite,meta.object-literal.key,support.variable.property,support.variable.object.process,support.variable.object.node",
          "settings": {
            "foreground": "#e2dfe4"
          }
        },
        {
          "scope": "entity.name.type",
          "settings": {
            "foreground": "#95e6cb"
          }
        },
        {
          "scope": "string",
          "settings": {
            "foreground": "#95e6adf3"
          }
        },
        {
          "scope": "storage",
          "settings": {
            "foreground": "#95dde6"
          }
        },
      ]
    },
  },
  "terminal.integrated.fontSize": 13,
  "screencastMode.keyboardOptions": {
    "showKeys": false,
    "showCommandGroups": true
  },
  "whichkey.sortOrder": "nonNumberFirst",
  "whichkey.bindingOverrides": [
    {
      "keys": "e",
      "name": "+Copilot",
      "type": "bindings",
      "bindings": [
        {
          "key": "a",
          "name": "Copilot: inline chat",
          "type": "command",
          "command": "inlineChat.start"
        },
        {
          "key": "e",
          "name": "Explain Code",
          "type": "command",
          "command": "github.copilot.chat.explain.palette"
        },
        {
          "key": "o",
          "name": "Open Chat Panel",
          "type": "command",
          "command": "workbench.action.chat.open"
        },
        {
          "key": ".",
          "name": "Generate Code",
          "type": "command",
          "command": "github.copilot.generate"
        },
        {
          "key": "t",
          "name": "Explain REPL output",
          "type": "command",
          "command": "runCommands",
          "args": {
            "commands": [
              "calva.showOutputTerminal",
              "workbench.action.terminal.selectAll",
              "github.copilot.terminal.explainTerminalSelection",
              "workbench.action.focusFirstEditorGroup",
            ]
          }
        },
      ]
    },
    {
      "keys": "c",
      "name": "+Clojure",
      "type": "bindings",
      "bindings": [
        {
          "key": "r",
          "name": "+REPL",
          "type": "bindings",
          "bindings": [
            {
              "key": "r",
              "name": "Run REPL",
              "type": "command",
              "command": "calva.jackIn"
            },
            {
              "key": "s",
              "name": "Stop REPL",
              "type": "command",
              "command": "calva.disconnect"
            },
            {
              "key": "o",
              "name": "Open REPL Output",
              "type": "command",
              "command": "calva.showResultOutputDestination",
              "args": true
            },
            {
              "key": "k",
              "name": "Clear REPL Output",
              "type": "command",
              "command": "runCommands",
              "args": {
                "commands": [
                  "calva.showOutputTerminal",
                  "workbench.action.terminal.clear",
                  "workbench.action.focusFirstEditorGroup",
                  "notifications.hideToasts"
                ]
              }
            },
            {
              "key": "x",
              "name": "Refresh REPL",
              "type": "command",
              "command": "calva.runCustomREPLCommand",
              "args": "x"
            },
            {
              "key": "X",
              "name": "Force Refresh REPL",
              "type": "command",
              "command": "calva.runCustomREPLCommand",
              "args": "x+"
            },
            {
              "key": "l",
              "name": "Load File into REPL",
              "type": "command",
              "command": "calva.loadFile"
            },
            {
              "key": "c",
              "name": "Interrupt REPL Evaluations",
              "type": "command",
              "command": "calva.interruptAllEvaluations"
            },
            {
              "key": "z",
              "name": "Unalias all namespaces in REPL",
              "type": "command",
              "command": "calva.runCustomREPLCommand",
              "args": "ns-"
            },
          ]
        },
        {
          "key": "t",
          "name": "+Test",
          "type": "bindings",
          "bindings": [
            {
              "key": "t",
              "name": "Run single test",
              "type": "command",
              "command": "calva.runCustomREPLCommand",
              "args": "t-"
            },
            {
              "key": "T",
              "name": "Run all tests in namespace",
              "type": "command",
              "command": "calva.runCustomREPLCommand",
              "args": "t"
            },
            {
              "key": "a",
              "name": "Run all tests in project",
              "type": "command",
              "command": "calva.runCustomREPLCommand",
              "args": "t+"
            }
          ]
        },
        {
          "key": "f",
          "name": "+Format",
          "type": "bindings",
          "bindings": [
            {
              "key": "f",
              "name": "Align current form",
              "type": "command",
              "command": "editor.action.formatDocument"
            },
            {
              "key": "r",
              "name": "Align current form (+vertical)",
              "type": "command",
              "command": "calva-fmt.alignCurrentForm"
            }
          ]
        },
        {
          "key": ".",
          "name": "#p",
          "type": "command",
          "command": "joyride.runUserScript",
          "args": "print.cljs"
        },
        {
          "key": ",",
          "name": "#t",
          "type": "command",
          "command": "joyride.runUserScript",
          "args": "tap.cljs"
        },
        {
          "key": "/",
          "name": "Ignore expression",
          "type": "command",
          "command": "joyride.runUserScript",
          "args": "ignore.cljs"
        }
      ]
    },
  ],
  "calva.myLeinProfiles": [
    "something"
  ],
}
