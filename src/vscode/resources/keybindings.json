// Place your key bindings in this file to override the defaults
[
    {
        "key": "shift shift",
        "command": "workbench.action.showCommands"
    },
    {
        "key": "ctrl ctrl",
        "command": "editor.action.quickFix",
        "when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
    },
    {
        "key": "cmd+.",
        "command": "aipopup.action.modal.generate",
        "when": "editorFocus && !composerBarIsVisible"
    },
    {
        "key": "ctrl+w right",
        "command": "workbench.action.navigateRight",
    },
    {
        "key": "ctrl+w left",
        "command": "workbench.action.navigateLeft",
    },
    {
        "key": "ctrl+w up",
        "command": "workbench.action.navigateUp",
    },
    {
        "key": "ctrl+w down",
        "command": "workbench.action.navigateDown",
    },
    {
        "key": "ctrl+w enter",
        "command": "workbench.action.toggleEditorWidths",
    },
    {
        "key": "ctrl+w w",
        "command": "workbench.action.focusSideBar",
        "when": "!sideBarVisible && viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "ctrl+w w",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "sideBarVisible"
    },
    {
        "key": "ctrl+w e",
        "command": "workbench.view.explorer"
    },
    {
        "key": "ctrl+w p",
        "command": "workbench.action.problems.focus"
    },
    {
        "key": "ctrl+w s",
        "command": "workbench.view.search.focus"
    },
    {
        "key": "ctrl+w x",
        "command": "workbench.view.extensions"
    },
    {
        "key": "ctrl+w j",
        "command": "atlascode.views.jira.assignedWorkItemsTreeView.focus"
    },
    {
        "key": "ctrl+w c",
        "command": "cursor.toggleAgentWindowIDEUnification",
        "when": "cursor.agentIdeUnification.featureGate && workbenchState != 'empty'"
    },
    {
        "key": "ctrl+shift+=",
        "command": "workbench.action.duplicateActiveEditorGroupRight"
    },
    {
        "key": "ctrl+shift+-",
        "command": "workbench.action.closeEditorsAndGroup",
    },
    {
        "key": "ctrl+=",
        "command": "workbench.action.increaseViewSize"
    },
    {
        "key": "ctrl+-",
        "command": "workbench.action.decreaseViewSize",
    },
    {
        "key": "ctrl+shift+right",
        "command": "workbench.action.navigateRight",
    },
    {
        "key": "ctrl+shift+left",
        "command": "workbench.action.navigateLeft",
    },
    {
        "key": "ctrl+shift+up",
        "command": "workbench.action.navigateUp",
    },
    {
        "key": "ctrl+shift+down",
        "command": "workbench.action.navigateDown",
    },
    {
        "key": "cmd+1",
        "command": "workbench.action.focusSideBar",
        "when": "!sideBarVisible && viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "cmd+1",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "sideBarVisible"
    },
    {
        "key": "cmd+2",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "!panelVisible"
    },
    {
        "key": "cmd+2",
        "command": "workbench.action.togglePanel",
        "when": "panelVisible"
    },
    {
        "key": "cmd+4",
        "command": "workbench.action.toggleAuxiliaryBar"
    },
    {
        "key": "cmd+3",
        "command": "claude-vscode.editor.openLast",
        "when": "!claudeVSCodeSessionsList.visible"
    },
    {
        "key": "cmd+3",
        "command": "workbench.action.toggleAuxiliaryBar",
        "when": "claudeVSCodeSessionsList.visible"
    },
    {
        "key": "cmd+'",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "editorFocus"
    },
    {
        "key": "cmd+'",
        "command": "workbench.action.togglePanel"
    },
    {
        "key": "cmd+shift+2",
        "command": "workbench.action.quickOpenTerm"
    },
    {
        "key": "cmd+5",
        "command": "workbench.actions.view.problems",
        "when": "editorFocus"
    },
    {
        "key": "cmd+5",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "!editorFocus"
    },
    {
        "key": "alt+tab",
        "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup",
        "when": "!activeEditorGroupEmpty && !terminalFocus"
    },
    {
        "key": "f1",
        "command": "editor.action.showHover"
    },
    {
        "key": "f1",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "explorerViewletFocus"
    },
    {
        "key": "f2",
        "command": "editor.action.rename",
        "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly"
    },
    {
        "key": "f3",
        "command": "editor.action.referenceSearch.trigger",
        "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor"
    },
    {
        "key": "cmd+,",
        "command": "editor.action.showContextMenu",
        "when": "textInputFocus"
    },
    {
        "key": "alt+-",
        "command": "workbench.action.decreaseViewSize"
    },
    {
        "key": "shift+cmd+=",
        "command": "workbench.action.zoomIn"
    },
    {
        "key": "shift+cmd+-",
        "command": "workbench.action.zoomOut"
    },
    {
        "key": "cmd+=",
        "command": "editor.action.fontZoomIn",
        "when": "!terminalFocus"
    },
    {
        "key": "cmd+=",
        "command": "workbench.action.terminal.fontZoomIn",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+-",
        "command": "editor.action.fontZoomOut",
        "when": "!terminalFocus"
    },
    {
        "key": "cmd+-",
        "command": "workbench.action.terminal.fontZoomOut",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+escape",
        "command": "notifications.hideToasts",
        "when": "notificationToastsVisible"
    },
    {
        "key": "ctrl+f f",
        "command": "editor.action.formatDocument",
        "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor"
    },
    {
        "key": "ctrl+f r",
        "command": "calva-fmt.alignCurrentForm",
        "when": "calva:keybindingsEnabled && editorTextFocus && !editorReadOnly && !hasOtherSuggestions && !suggestWidgetVisible && editorLangId == 'clojure'"
    },
    {
        "key": "ctrl+.",
        "command": "joyride.runUserScript",
        "args": "print.cljs",
        "when": "editorTextFocus && !editorReadOnly && editorLangId =~ /clojure|scheme|lisp/"
    },
    {
        "key": "ctrl+,",
        "command": "joyride.runUserScript",
        "args": "tap.cljs",
        "when": "editorTextFocus && !editorReadOnly && editorLangId =~ /clojure|scheme|lisp/"
    },
    {
        "key": "ctrl+/",
        "command": "joyride.runUserScript",
        "args": "ignore.cljs",
        "when": "editorTextFocus && !editorReadOnly && editorLangId =~ /clojure|scheme|lisp/"
    },
    {
        "key": "ctrl+shift+c",
        "command": "joyride.runUserScript",
        "args": "copy_qualified_name.cljs",
        "when": "editorTextFocus && editorLangId =~ /clojure|scheme|lisp/"
    },
    {
        "key": "ctrl+shift+cmd+c",
        "command": "joyride.runUserScript",
        "args": "copy_github_link.cljs",
        "when": "editorTextFocus && editorLangId =~ /clojure|scheme|lisp/"
    },
    {
        "key": "ctrl+shift+g",
        "command": "joyride.runUserScript",
        "args": "copy_github_link.cljs",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+t a",
        "command": "calva.runCustomREPLCommand",
        "when": "calva:connected && editorTextFocus && editorLangId == 'clojure'",
        "args": "tk+"
    },
    {
        "key": "ctrl+t t",
        "command": "calva.runCustomREPLCommand",
        "when": "calva:connected && editorTextFocus && editorLangId == 'clojure'",
        "args": "tk-"
