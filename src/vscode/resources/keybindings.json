    {
        "key": "ctrl+x x",
        "command": "mcp.reloadClient",
        "when": ""
    },
    {
        "key": "ctrl+r r",
        "command": "calva.jackIn",
        "when": "calva:keybindingsEnabled && editorTextFocus && workspaceFolderCount > 0"
    },
    {
        "key": "ctrl+r s",
        "command": "calva.jackOut",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+r o",
        "command": "calva.showResultOutputDestination",
        "args": true,
        "when": "calva:connected && calva:keybindingsEnabled && editorTextFocus"
    },
    {
        "key": "ctrl+r backspace",
        "command": "runCommands",
        "args": {
            "commands": [
                "calva.showOutputTerminal",
                "workbench.action.terminal.clear",
                "workbench.action.focusFirstEditorGroup",
                "notifications.hideToasts"
            ]
        },
        "when": "calva:connected && calva:keybindingsEnabled && editorTextFocus"
    },
    {
        "key": "ctrl+r l",
        "command": "calva.loadFile",
        "when": "calva:connected && calva:keybindingsEnabled && editorTextFocus && editorLangId == 'clojure'"
    },
    {
        "key": "ctrl+r c",
        "command": "calva.interruptAllEvaluations",
        "when": "calva:connected && calva:keybindingsEnabled && editorTextFocus && editorLangId == 'clojure'"
    },
