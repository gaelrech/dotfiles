cmux_workspace() {
  local name="$1"
  local id
  id=$(cmux list-workspaces --json | jq -r --arg name "$name" \
    '.[] | select(.name == $name) | .id' | head -1)

  if [[ -n "$id" ]]; then
    cmux select-workspace --workspace "$id"
  else
    cmux new-workspace --name "$name"
  fi
}

claude-fork() {
  # Resolve current session JSONL from the most recent file in this project
  local project_dir session_file session_id fork_id fork_file
  project_dir="$HOME/.claude/projects/$(echo "$PWD" | tr '/.' '-')"
  session_file=$(ls -t "$project_dir"/*.jsonl 2>/dev/null | head -1)
  session_id=$(tail -1 "$session_file" 2>/dev/null \
    | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('sessionId',''))" 2>/dev/null)

  if [[ -z "$session_id" || -z "$session_file" ]]; then
    echo "claude-fork: could not determine current session" >&2
    return 1
  fi

  # Create a fork by copying the session JSONL to a new UUID
  # (--fork-session doesn't work while the source session is active)
  fork_id=$(python3 -c "import uuid; print(uuid.uuid4())")
  fork_file="$project_dir/$fork_id.jsonl"
  cp "$session_file" "$fork_file"

  # Snapshot existing surface refs before the split
  local before_surfaces
  before_surfaces=$(cmux list-pane-surfaces 2>/dev/null | grep -oE 'surface:[0-9]+' | sort)

  # Create a vertical split in the current workspace (same as CMD+D)
  cmux new-split right > /dev/null

  # Identify the newly created surface
  local new_surface
  new_surface=$(comm -23 \
    <(cmux list-pane-surfaces 2>/dev/null | grep -oE 'surface:[0-9]+' | sort) \
    <(echo "$before_surfaces") \
    | head -1)

  if [[ -z "$new_surface" ]]; then
    echo "claude-fork: could not identify new split surface" >&2
    rm -f "$fork_file"
    return 1
  fi

  # Resume the fork in the new pane — it has the same history but a fresh session ID
  cmux send --surface "$new_surface" "claude --resume $fork_id" > /dev/null
  cmux send-key --surface "$new_surface" "Enter" > /dev/null
}

set_default_app() {
  local bundle_id="$1"
  shift
  if [[ -z "$bundle_id" || $# -eq 0 ]]; then
    echo "Usage: set_default_app <bundle-id> <ext> [<ext2> ...]"
    echo "Example: set_default_app com.todesktop.230313mzl4w4u92 md txt"
    return 1
  fi
  local exts=("$@")
  swift - "$bundle_id" "${exts[@]}" <<'SWIFT'
import Foundation
import CoreServices
import UniformTypeIdentifiers

let args = CommandLine.arguments
let bundleID = args[1] as CFString
for raw in args.dropFirst(2) {
    let ext = raw.hasPrefix(".") ? String(raw.dropFirst()) : raw
    guard let utType = UTType(filenameExtension: ext) else {
        print("✗ Could not resolve UTI for .\(ext)")
        continue
    }
    let status = LSSetDefaultRoleHandlerForContentType(utType.identifier as CFString, .all, bundleID)
    if status == noErr {
        print("✓ .\(ext) → \(args[1])  (UTI: \(utType.identifier))")
    } else {
        print("✗ .\(ext) failed (error \(status))")
    }
}
SWIFT
}

