create_symlink () {
    local SOURCE="$1"
    local DESTINATION="$2"
    ln -sf "$SOURCE" "$DESTINATION"
    printf "${NORMAL}%s${GREEN}%s${NORMAL}%s\n" ">> Symlink " "$(basename "$SOURCE")" " created"
}

kill_port() {
  lsof -i tcp:$1
  if [[ $? -ne 0 ]]; then
    printf "\nPort $1 is not in use\n"
    return
  fi
  
  local pid=$( lsof -ti tcp:$1 )
  
  printf "\nDo you wish to kill PID $pid? (y-n)\n"
  
  read -t 5 -k 1 answer
    printf "\n"
    if [[ $answer == [yY] ]]; then
      kill -9 $pid
    fi
}

