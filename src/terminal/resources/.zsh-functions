kill-orphans() {
  # Usage: kill-orphans [--dry-run]
  # Finds and kills orphaned processes: MCP servers (PPID=1) and idle REPLs
  # (JVM process groups with no parent shell).
  local dry_run=false
  [[ "$1" == "--dry-run" ]] && dry_run=true

  local mypid=$$
  local -a pids=()

  # --- PPID=1 orphans (MCP servers, wrappers, REPLs) ---
  local ps_snapshot=$(ps -eo pid,ppid,command)

  # Java/Leiningen/nREPL
  local java_pids=$(echo "$ps_snapshot" | awk -v me="$mypid" \
    '$2 == 1 && /java.*(leiningen|nrepl|clojure)/ && $1 != me {print $1}')
  for p in ${=java_pids}; do
    pids+=($p)
    local kids=$(ps -eo pid,ppid | awk -v parent="$p" '$2 == parent {print $1}')
    for k in ${=kids}; do pids+=($k); done
  done

  # Node — MCP servers
  local node_pids=$(echo "$ps_snapshot" | awk -v me="$mypid" \
    '$2 == 1 && /node/ && (/playwright/ || /workspace-server/ || /mcp/) && $1 != me {print $1}')
  for p in ${=node_pids}; do pids+=($p); done

  # Python/uv — MCP servers
  local python_pids=$(echo "$ps_snapshot" | awk -v me="$mypid" \
    '$2 == 1 && (/python/ || /uv/) && (/mcp/ || /voicemode/) && $1 != me {print $1}')
  for p in ${=python_pids}; do pids+=($p); done

  # Bash wrappers that launch MCP servers
  local bash_pids=$(echo "$ps_snapshot" | awk -v me="$mypid" \
    '$2 == 1 && /bash/ && /mcp/ && $1 != me {print $1}')
  for p in ${=bash_pids}; do
    pids+=($p)
    local kids=$(ps -eo pid,ppid | awk -v parent="$p" '$2 == parent {print $1}')
    for k in ${=kids}; do pids+=($k); done
  done

  # ht-mcp binaries
  local htmcp_pids=$(echo "$ps_snapshot" | awk -v me="$mypid" \
    '$2 == 1 && /ht-mcp/ && $1 != me {print $1}')
  for p in ${=htmcp_pids}; do pids+=($p); done

  # --- Idle REPLs (JVM process groups with no non-JVM member) ---
  local pgids=$(ps -eo pgid,pid,comm,args | awk '/[Jj]ava|[Cc]lojure|[Ll]ein/ {print $1}' | sort -u)
  for pgid in ${=pgids}; do
    if ps -eo pgid,comm,args | awk -v pgid="$pgid" \
      '$1==pgid && !/[Jj]ava|[Cc]lojure|[Ll]ein/ {found=1} END {if(found) exit 1; else exit 0}'; then
      local repl_pids=$(ps -eo pgid,pid,comm,args | awk -v pgid="$pgid" \
        '$1==pgid && /[Jj]ava|[Cc]lojure|[Ll]ein/ {print $2}')
      for p in ${=repl_pids}; do pids+=($p); done
    fi
  done

  # --- Deduplicate ---
  local -a unique_pids=(${(u)pids})

  if (( ${#unique_pids} == 0 )); then
    echo "No orphaned processes found."
    return 0
  fi

  # --- Compute memory ---
  local mem_kb=0
  for p in "${unique_pids[@]}"; do
    local rss=$(ps -o rss= -p "$p" 2>/dev/null | tr -d ' ')
    [[ -n "$rss" ]] && mem_kb=$((mem_kb + rss))
  done
  local mem_mb=$((mem_kb / 1024))

  if $dry_run; then
    echo "Would kill ${#unique_pids} orphaned processes (~${mem_mb}MB):"
    for p in "${unique_pids[@]}"; do
      ps -o pid,ppid,rss,command -p "$p" 2>/dev/null | tail -1
    done
    return 0
  fi

  kill "${unique_pids[@]}" 2>/dev/null || true
  sleep 2
  kill -9 "${unique_pids[@]}" 2>/dev/null || true

  echo "Killed ${#unique_pids} orphaned processes (~${mem_mb}MB freed)"
}

